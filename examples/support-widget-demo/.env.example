# Where your Support Tool instance is running.
SUPPORT_TOOL_URL=http://localhost:3000

# An API key generated at /admin/api-keys in Support Tool (admin only).
# The raw key is shown exactly once at creation — paste it here.
# It lives ONLY on this backend; it is never sent to the browser.
SUPPORT_TOOL_API_KEY=stk_live_replace_me

# Port this demo site listens on.
PORT=4321
